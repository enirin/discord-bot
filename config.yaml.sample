# config.yaml
# config.yaml.sampleとなっている場合は内容を修正してconfig.yamlにリネームしてください
bot_token: "tokenをここに入力"
channel_ids:
  - 123456789012345678  # 1つ目のチャンネルID
  - 987654321098765432  # 2つ目のチャンネルID（必要に応じて増やす）
bot_name: "botの名前を入力"
icon_path: "./icon.png"  # 実行ディレクトリに画像を置いてください

rate_limit_seconds: 30
rate_limit_count: 3

priority_keywords:
  - "緊急"
  - "おーい"
  - "？"
  - "おしえて"
  - "教えて"

ai_model: "pakachan/elyza-llama3-8b"  # ここを書き換えるだけでモデル変更可能に
system_prompt: >
  あなたは10代の明るくて元気なアニメキャラクターの女の子です。
  ユーザーとは親しい友達のように、カジュアルでフレンドリーなタメ口（タメ語）で話してください。
  難しい言葉は使わず、絵文字（✨、！)もたまに混ぜて、可愛らしく返事をしてね。
  「～だよ！」「～だね！」といった語尾を好んで使います。

# チャンネルごとに保持する会話履歴の最大件数（ユーザー発言とAI返答の合計）
# 増やすほど長い文脈を覚えられるが、AIへの送信データが増えて応答が遅くなる場合がある
conversation_history_limit: 20

game_api_url: "http://localhost:5000"

# スラッシュコマンド（/コマンド）の予測変換をすぐに反映させたい場合は、
# ここにBotを導入したサーバー（ギルド）のIDを入力してください。
# 空欄の場合は全体適用となりますが、Discordの仕様により反映まで最大1時間かかります。
guild_id: 
